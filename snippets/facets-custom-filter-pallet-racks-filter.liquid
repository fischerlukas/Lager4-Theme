{%- liquid
  assign filter_index = index | default: 1
-%}

{%- case filter.type -%}

  {%- when 'boolean' or 'list' -%}
    <div class="facets-custom-filter-pallet-racks__filter js-filter" data-index="{{ filter_index }}-{{ location }}">
      <details class="facets-custom-filter-pallet-racks__disclosure" data-custom-filter-pallet-racks-disclosure>
        <summary class="facets-custom-filter-pallet-racks__summary" aria-label="{{ filter.label | escape }}">
          <span class="facets-custom-filter-pallet-racks__summary-label">{{ filter.label | escape }}</span>
          <span class="facets-custom-filter-pallet-racks__summary-value">
            {%- if filter.active_values.size > 0 -%}
              {{ filter.active_values.size }} {{ 'collections.filters_selected' | t: count: filter.active_values.size }}
            {%- else -%}
              auswählen
            {%- endif -%}
          </span>
        </summary>
        <div class="facets-custom-filter-pallet-racks__panel">
          <div class="facets-custom-filter-pallet-racks__panel-head">
            <span class="facets-custom-filter-pallet-racks__selected no-js-hidden">
              {{ 'collections.filters_selected' | t: count: filter.active_values.size }}
            </span>
            <a href="{{ filter.url_to_remove }}" class="facets-custom-filter-pallet-racks__reset link underlined-link js-facet-remove">
              {{ 'collections.reset' | t }}
            </a>
          </div>
          <ul class="facets-custom-filter-pallet-racks__list list-unstyled" role="list">
            {%- for value in filter.values -%}
              <li class="facets-custom-filter-pallet-racks__item">
                <label class="facet-checkbox{% if value.count == 0 and value.active == false %} facet-checkbox--disabled{% endif %}">
                  <input
                    type="checkbox"
                    class="styled-checkbox"
                    name="{{ value.param_name }}"
                    value="{{ value.value }}"
                    {% if value.active %}checked{% endif %}
                    {% if value.count == 0 and value.active == false %}disabled{% endif %}
                  >
                  {{ value.label | escape }}
                  <span class="facets-custom-filter-pallet-racks__count-inline">({{ value.count }})</span>
                </label>
              </li>
            {%- endfor -%}
          </ul>
        </div>
      </details>
    </div>

  {%- when 'price_range' -%}
    {%- liquid
      assign currencies_using_comma_decimals = 'ANG,ARS,BRL,BYN,BYR,CLF,CLP,COP,CRC,CZK,DKK,EUR,HRK,HUF,IDR,ISK,MZN,NOK,PLN,RON,RUB,TRY,UYU,VES,VND' | split: ','
      assign uses_comma_decimals = false
      if currencies_using_comma_decimals contains cart.currency.iso_code
        assign uses_comma_decimals = true
      endif
    -%}
    <div class="facets-custom-filter-pallet-racks__filter js-filter" data-index="{{ filter_index }}-{{ location }}">
      <details class="facets-custom-filter-pallet-racks__disclosure" data-custom-filter-pallet-racks-disclosure>
        <summary class="facets-custom-filter-pallet-racks__summary" aria-label="{{ filter.label | escape }}">
          <span class="facets-custom-filter-pallet-racks__summary-label">{{ filter.label | escape }}</span>
          <span class="facets-custom-filter-pallet-racks__summary-value">
            {%- if filter.min_value.value != nil or filter.max_value.value != nil -%}
              {%- if filter.min_value.value -%}{{ filter.min_value.value | money }}{%- else -%}{{ 0 | money }}{%- endif -%}
              –
              {%- if filter.max_value.value -%}{{ filter.max_value.value | money }}{%- else -%}{{ filter.range_max | money }}{%- endif -%}
            {%- else -%}
              auswählen
            {%- endif -%}
          </span>
        </summary>
        <div class="facets-custom-filter-pallet-racks__panel">
          <div class="facets-custom-filter-pallet-racks__panel-head">
            {%- assign max_price_amount = filter.range_max | money -%}
            <span class="facets-custom-filter-pallet-racks__selected">{{ "collections.max_price_html" | t: price: max_price_amount }}</span>
            <a href="{{ filter.url_to_remove }}" class="facets-custom-filter-pallet-racks__reset link underlined-link js-facet-remove">
              {{ 'collections.reset' | t }}
            </a>
          </div>

          <price-range class="facets-custom-filter-pallet-racks__price">
            <div class="field">
              <label class="field__label visually-hidden" for="CustomFilterPalletRacks-Filter-{{ filter.label | escape }}-GTE">{{ 'collections.from' | t }}</label>
              <span class="field__currency">{{ cart.currency.symbol }}</span>
              <input
                class="field__input"
                name="{{ filter.min_value.param_name }}"
                id="CustomFilterPalletRacks-Filter-{{ filter.label | escape }}-GTE"
                {%- if filter.min_value.value -%}
                  {%- if uses_comma_decimals -%}value="{{ filter.min_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' | round }}"{%- else -%}value="{{ filter.min_value.value | money_without_currency | replace: ',', '' | round }}"{% endif %}
                {%- endif -%}
                type="number"
                placeholder="0"
                min="0"
                {%- if uses_comma_decimals -%}max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' | round }}"{%- else -%}max="{{ filter.range_max | money_without_currency | replace: ',', '' | round }}"{% endif %}
              >
            </div>

            <div class="field">
              <label class="field__label visually-hidden" for="CustomFilterPalletRacks-Filter-{{ filter.label | escape }}-LTE">{{ 'collections.to' | t }}</label>
              <span class="field__currency">{{ cart.currency.symbol }}</span>
              <input
                class="field__input"
                name="{{ filter.max_value.param_name }}"
                id="CustomFilterPalletRacks-Filter-{{ filter.label | escape }}-LTE"
                {%- if filter.max_value.value -%}
                  {%- if uses_comma_decimals -%}value="{{ filter.max_value.value | money_without_currency | replace: '.', '' | replace: ',', '.' | ceil }}"{%- else -%}value="{{ filter.max_value.value | money_without_currency | replace: ',', '' | ceil }}"{% endif %}
                {%- endif -%}
                type="number"
                min="0"
                {%- if uses_comma_decimals -%}
                  placeholder="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' | ceil }}"
                  max="{{ filter.range_max | money_without_currency | replace: '.', '' | replace: ',', '.' | ceil }}"
                {%- else -%}
                  placeholder="{{ filter.range_max | money_without_currency | replace: ',', '' | ceil }}"
                  max="{{ filter.range_max | money_without_currency | replace: ',', '' | ceil }}"
                {% endif %}
              >
            </div>
          </price-range>

          <div
            class="facets-custom-filter-pallet-racks__price-slider"
            data-js-price-range-slider
          ></div>
        </div>
      </details>
    </div>

{%- endcase -%}

